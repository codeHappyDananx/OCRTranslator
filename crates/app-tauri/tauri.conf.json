{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OCR Translator",
  "version": "0.1.0",
  "identifier": "local.ocr-translator.app",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OCR Translator",
        "url": "index.html",
        "width": 920,
        "height": 970,
        "minWidth": 760,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/SnippingTool"]
  }
}
